class Solution {
public:
    bool isPalindrome(string s) {
        string ans;
        for(char c:s){
            if(isalnum(c))  ans+=c;
        }
        transform(ans.begin(), ans.end(), ans.begin(), ::tolower);
        int low=0;
        int high=ans.length()-1;
        while(low<high){
            if(ans[low]!=ans[high]) return false;
            low++;
            high--;
        }
        return true;
    }
};
