class Solution {
public:
    void duplicateZeros(vector<int>& arr) {
        vector<int>v;
        for(int x:arr){
            if(x==0){
                v.push_back(x);
                v.push_back(x);
            }
            else    v.push_back(x);
        }
        for(int i=0;i<arr.size();i++){
            arr[i]=v[i];
        }
        
    }
};
